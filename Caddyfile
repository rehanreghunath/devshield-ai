{$PUBLIC_DOMAIN:http://localhost} {
    # Route webhook and API traffic to the backend
    handle /api/webhooks/* {
        reverse_proxy backend:8080
    }

    handle /api/jobs* {
        reverse_proxy backend:8080
    }

    handle /api/reviews* {
        reverse_proxy backend:8080
    }

    # All other traffic goes to the Next.js frontend
    handle {
        reverse_proxy frontend:3000
    }
}
