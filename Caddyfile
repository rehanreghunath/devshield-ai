{$PUBLIC_DOMAIN:http://localhost} {
    # NextAuth handles authentication
    handle /api/auth/* {
        reverse_proxy frontend:3000
    }

    # All other API traffic goes to the backend
    handle /api/* {
        reverse_proxy backend:8080
    }

    # All other traffic goes to the Next.js frontend
    handle {
        reverse_proxy frontend:3000
    }
}
